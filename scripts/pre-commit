#!/usr/bin/env bash

# Redirect output to stderr
exec 1>&2

set -euo pipefail

exit_code=0

# List of changed files, excluding deleted ones
GIT_CMD=${GIT_CMD:-"git diff --name-only --cached --diff-filter=d"}

check_secrets() {
  local files
  files=$($GIT_CMD)

  for f in $files; do
    # Only look in 'secrets' directories
    if [[ "$f" == *"/secrets/"* ]] || [[ "$f" == secrets/* ]]; then

      content=$(git show ":$f")

      if ! echo "$content" | grep -q "BEGIN AGE ENCRYPTED FILE"; then
        echo "ERROR: Unencrypted secret detected in $f"
        exit_code=1
      fi
    fi
  done
}

check_secrets

exit $exit_code
